{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "labels": [
    "dependencies",
    "automated"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchFileNames": [
        "flatpaks/**/release.yaml",
        "flatpaks/**/manifest.yaml"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "quay.io/jlebon/chunkah"
      ],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update release.yaml bundle-repack packages: version, url, and sha256 fields (allows intervening comment/config lines between version and url)",
      "managerFilePatterns": [
        "/^flatpaks/[^/]+/release\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>v?[0-9]+\\.[0-9.]+[^\\n]*)\\n(?:[^\\n]*\\n){0,5}url:\\s*(?<urlPrefix>https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/)v?[0-9]+\\.[0-9.]+[^/]*/(?<urlSuffix>[^\\n]+)\\nsha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "autoReplaceStringTemplate": "version: {{{newValue}}}\nurl: {{{urlPrefix}}}{{{newValue}}}/{{{urlSuffix}}}\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update manifest.yaml flatpak-builder packages: x-version, GitHub archive url, and sha256 fields",
      "managerFilePatterns": [
        "/^flatpaks/[^/]+/manifest\\.yaml$/"
      ],
      "matchStrings": [
        "x-version:\\s*\"(?<currentValue>[^\"]+)\"\\n\\s*url:\\s*https://github\\.com/(?<depName>[^/]+/[^/]+)/archive/refs/tags/v[^\\s/]+\\.tar\\.gz\\n\\s*sha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "x-version: \"{{{newValue}}}\"\nurl: https://github.com/{{{depName}}}/archive/refs/tags/v{{{newValue}}}.tar.gz\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update chunkah container image tag in Justfile and build.yml",
      "managerFilePatterns": [
        "/^Justfile$/",
        "/^\\.github/workflows/build\\.yml$/"
      ],
      "matchStrings": [
        "quay\\.io/jlebon/chunkah:(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "quay.io/jlebon/chunkah",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update yq version in Justfile",
      "managerFilePatterns": [
        "/^Justfile$/"
      ],
      "matchStrings": [
        "YQ_VERSION=\"(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mikefarah/yq",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update oras version in Justfile",
      "managerFilePatterns": [
        "/^Justfile$/"
      ],
      "matchStrings": [
        "ORAS_VERSION=\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "oras-project/oras",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
