{
  "name": "testhub — flatpak OCI remote",
  "image": "ghcr.io/flathub-infra/flatpak-github-actions:gnome-49",
  "runArgs": [
    "--security-opt", "label=disable",
    "--security-opt", "unmask=/proc/*",
    "--device", "/dev/net/tun",
    "--device", "/dev/kvm",
    "--privileged"
  ],
  "capAdd": ["SYS_ADMIN"],
  "containerEnv": {
    "SOURCE_DATE_EPOCH": "0"
  },
  "postCreateCommand": "curl -fsSL https://github.com/casey/just/releases/download/1.40.0/just-1.40.0-x86_64-unknown-linux-musl.tar.gz | tar -xz -C /usr/local/bin just && just install-tools-yq",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "ms-vscode.makefile-tools"
      ]
    }
  }
}
